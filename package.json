{
  "name": "n8n-nodes-galileo",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Galileo Financial Technologies providing 24 resources and 200+ operations for card issuing, account management, ACH transfers, digital wallets, and BaaS functionality. Includes sandbox testing support.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-galileo.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-galileo",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-galileo/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "galileo",
    "fintech",
    "banking",
    "baas",
    "banking-as-a-service",
    "card-issuing",
    "payments",
    "ach",
    "digital-wallet",
    "apple-pay",
    "google-pay",
    "kyc",
    "fraud-prevention"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GalileoApi.credentials.js",
      "dist/credentials/GalileoOAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Galileo/Galileo.node.js",
      "dist/nodes/Galileo/GalileoTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.30.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
